# ===============================================
# ZTYX Web - Environment Variables
# ===============================================

# ===============================================
# Database (Supabase PostgreSQL)
# ===============================================
DATABASE_URL="postgresql://user:password@host:5432/ztyx?schema=public"

# ===============================================
# Authentication (NextAuth.js)
# ===============================================
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Resend for magic links)
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@ztyx.com"

# ===============================================
# Caching (Upstash Redis)
# ===============================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ===============================================
# CMS (Sanity.io) - Optional for Phase 2
# ===============================================
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN=""

# ===============================================
# External Services
# ===============================================
NEXT_PUBLIC_ANALYTICS_ID=""
ANALYTICS_WRITE_KEY=""

# ===============================================
# Site Configuration
# ===============================================
NEXT_PUBLIC_SITE_URL="https://ztyx.com"
NEXT_PUBLIC_SITE_NAME="ZTYX"